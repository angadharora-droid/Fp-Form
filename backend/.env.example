# Copy this file to .env and adjust values.

# --- Server ---
PORT=3001
SECRET_KEY=change-me-in-production

# Comma-separated venue frontend origins allowed by CORS.
FRONTEND_ORIGINS=http://localhost:5173

# --- Venue users (JSON objects; keep real passwords only in environment) ---
# A venue with an empty object is disabled; the backend can still serve the
# other configured venues.
AMRAVATI_ALLOWED_USERS={"kashish":"Pass@2026"}
NAGPUR_ALLOWED_USERS={"veer":"veer@2026","irfan":"irfan@2026","abhishek":"abhishek@2026"}
DALI_ALLOWED_USERS={"sandeep":"sandeep@2026","narendra":"narendra@2026"}
NAVI_MUMBAI_ALLOWED_USERS={"shabbir":"shabbir@2026","tarneem":"tarneem@2026","umesh":"umesh@2026","ravi":"ravi@2026"}
PABLO_ALLOWED_USERS={"irfan":"irfan@2026","vinod":"vinod@2026","tushar":"tushar@2026"}

# --- MongoDB (local) ---
MONGODB_URI=mongodb://127.0.0.1:27017/amravti_fp

# --- Email (booking PDF sent on submit) ---
# SMTP account used by the shared backend. Port 465 =>
# SMTP_SECURE=true; port 587 => SMTP_SECURE=false (STARTTLS).
# Leave blank to disable emailing.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Centre Point Hospitality <no-reply@cpgh.in>
