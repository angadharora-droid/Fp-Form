# Copy this file to .env and adjust for your setup.
#
# Base URL of the backend API (no trailing slash).
#   Local dev:   http://localhost:3001
#   Production:  set VITE_API_BASE in the Vercel dashboard to your deployed
#                backend URL, e.g. https://fp-form-backend.onrender.com
#
# Note: Vite only exposes variables prefixed with VITE_ to the browser.
VITE_API_BASE=http://localhost:3001
